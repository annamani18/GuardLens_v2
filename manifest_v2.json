{
  "manifest_version": 3,
  "name": "GuardLens",
  "version": "2.0.0",
  "description": "AI-powered Dark Pattern detector with on-device Gemini Nano analysis",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://*.amazon.in/*",
    "https://*.flipkart.com/*",
    "https://*.myntra.com/*",
    "https://*.ajio.com/*",
    "https://*.meesho.com/*",
    "https://*.snapdeal.com/*",
    "https://*.amazon.com/*",
    "https://*.ebay.com/*",
    "https://*.walmart.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.amazon.in/*",
        "https://*.flipkart.com/*",
        "https://*.myntra.com/*",
        "https://*.ajio.com/*",
        "https://*.meesho.com/*",
        "https://*.snapdeal.com/*",
        "https://*.amazon.com/*",
        "https://*.ebay.com/*",
        "https://*.walmart.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
